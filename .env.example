# 계정 관리 페이지 접근 키 (/create-accounts 접속 후 입력)
ADMIN_ACCOUNTS_KEY=finalent

# 예전 단일 Redis 키에 남아 있던 데이터를 마이그레이션할 계정 id (기본 finalent). 신규 계정은 이 값이 아니면 레거시를 복사하지 않음.
# LEGACY_ACCOUNT_ID=finalent

# Upstash Redis (프로덕션 필수: 미설정 시 메모리만 사용 → 서버 재시작 시 멤버/미션 등 데이터 초기화됨)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
