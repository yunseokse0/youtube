# 계정 관리 페이지 접근 키 (/create-accounts 접속 후 입력)
ADMIN_ACCOUNTS_KEY=finalent

# HTTP(IP)로 배포할 때 로그인 쿠키가 안 붙으면 false (HTTPS 후 true 또는 삭제)
# AUTH_COOKIE_SECURE=false

# 예전 단일 Redis 키에 남아 있던 데이터를 마이그레이션할 계정 id (기본 finalent). 신규 계정은 이 값이 아니면 레거시를 복사하지 않음.
# LEGACY_ACCOUNT_ID=finalent

# Upstash Redis (프로덕션 필수: 미설정 시 메모리만 사용 → 서버 재시작 시 멤버/미션 등 데이터 초기화됨)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Supabase Storage (선택 — GitHub 전용 모드면 비움)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=image

# --- 시그 이미지: AWS·자체 서버 PC 업로드 (기본) ---
# PC에서 업로드한 GIF/PNG는 public/uploads/sigs 에 저장되고 /uploads/sigs/... URL로 제공됩니다.
# AWS EC2 등 Render가 아닌 환경에서는 Supabase 없이도 디스크 업로드가 기본 동작합니다.
# SIG_SERVE_SIG_IMAGES_FROM_DISK=true  (명시적 설정, Render에서는 SIG_SERVE_SIG_IMAGES_FROM_DISK_ON_RENDER=1 필요)

# --- (레거시) GitHub 번들 전용 — AWS EC2 디스크 업로드 시 반드시 끄기 ---
# NEXT_PUBLIC_SIG_IMAGES_GITHUB_ONLY=true   ← 켜면 /uploads 가 GitHub raw 로 바뀌어 404
# NEXT_PUBLIC_SIG_ROLLING_GITHUB_BASE=off   ← EC2 기본 권장

# --- FTP (FileZilla Server 등) — 서버 전용, Git 커밋 금지 ---
# FTP_HOST=127.0.0.1
# FTP_PORT=21
# FTP_USER=Windows로그인계정
# FTP_PASSWORD=
# FTP_SECURE=false
# FTPS 명시: FTP_SECURE=true  /  암시적 FTPS: FTP_SECURE=implicit
# 시그 이미지를 FTP에 올리고 동일 사이트 URL `/api/ftp/image/sigs/...` 로 제공 (CDN 캐시 헤더)
# SIG_FTP_IMAGE_UPLOAD=true
# FTP 서버 루트 기준 저장 폴더 접두 (비우면 /sigs/<계정>/파일명)
# FTP_SIG_BASE_PATH=

# 투네이션 Alertbox 브라우저 소켓 — 명시적으로 true일 때만 toon.at에 연결합니다.
# NEXT_PUBLIC_TOONATION_SOCKET_ENABLED=true

# OBS 오버레이: SSE 끊김 시에만 느린 상태 폴링(ms). 기본 90000. 끄려면 0
# NEXT_PUBLIC_OVERLAY_SSE_FALLBACK_MS=90000
# (사용 안 함) 주기 폴링 디버그만 — 방송 URL에 overlayPollMs 넣지 마세요
# NEXT_PUBLIC_OVERLAY_DEBUG_POLL_MS=0

# 관리자「저장소 시그 이미지」목록: 배포 디스크 외 GitHub 트리와 병합 (NEXT_PUBLIC_SIG_ROLLING_GITHUB_BASE의 owner/repo/ref 파싱).
# 비공개 저장소·API 한도 완화: SIG_BUNDLED_GITHUB_TOKEN 또는 GITHUB_TOKEN
# OBS GET /api/state?pick=overlay|sig-sales|donor-rankings 등 — 축소 JSON(기본 on). off=전체 JSON
# 후원 순위: donors·테마 변경 시만 SSE+GET (회전판만 바뀌면 요청 없음)
# STATE_API_OVERLAY_PICK=off
# pick=overlay-donors 시 donors 상한(기본 300)
# STATE_API_OVERLAY_DONORS_MAX=300
# Upstash 상태 gzip(Render 프로덕션 기본 on). off=비압축 JSON
# UPSTASH_STATE_GZIP=off
# GitHub 트리 API 응답 서버 메모리 캐시(ms). 기본 3600000(1h). 0=매번 API 호출
# SIG_BUNDLED_GITHUB_CACHE_MS=3600000
# SIG_BUNDLED_GITHUB_LIST=off
# SIG_BUNDLED_GITHUB_REPO=owner/repo
# SIG_BUNDLED_GITHUB_REF=main
